# Server port — Render assigns 10000 automatically, use 5050 locally
PORT=5050

# MongoDB connection string
# Local:      mongodb://localhost:27017/workforce
# Production: mongodb+srv://<user>:<password>@cluster.mongodb.net/workforce
MONGODB_URI=mongodb://localhost:27017/workforce

# JWT
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRE=7d

# Multi-tenancy app identifier
APP_NAME=workforce
